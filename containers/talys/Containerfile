# TALYS heavy-ion cross-section generator
#
# No registration required — TALYS is freely available from the IAEA.
#
# Build:  podman build -t nucl-talys containers/talys/
# Run:    ./containers/talys/run.sh
# Output: hi-xs/ parquet files (mounted volume)

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        gfortran \
        make \
        wget \
        python3 \
        python3-pip \
        python3-venv \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps into a venv to avoid externally-managed-environment errors
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir polars numpy

# Download, build, and install TALYS-2.2 from IAEA (no registration needed)
WORKDIR /opt/talys-build
RUN wget -q https://nds.iaea.org/talys/codes/talys.tar \
    && tar xf talys.tar \
    && cd talys \
    && make \
    && cp source/talys /usr/local/bin/talys \
    && cp -r structure /opt/talys-structure \
    && cd / \
    && rm -rf /opt/talys-build

ENV TALYS_STRUCTURE=/opt/talys-structure

COPY generate.py /opt/generate.py

WORKDIR /work
ENTRYPOINT ["python3", "/opt/generate.py"]
