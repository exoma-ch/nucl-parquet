  "shared": {
    "meta": {
      "path": "meta/",
      "files": {
        "abundances": "abundances.parquet",
        "decay": "decay.parquet",
        "elements": "elements.parquet"
      }
    },
    "stopping": {
      "path": "stopping/",
      "files": {
        "stopping": "stopping.parquet",
        "catima": "catima.parquet"
      },
      "sources": [
        "PSTAR",
        "ASTAR",
        "ESTAR",
        "ICRU73",
        "MSTAR"
      ],
      "catima": {
        "proj_Z_range": [
          1,
          92
        ],
        "target_Z_range": [
          1,
          92
        ],
        "energy_unit": "MeV/u",
        "note": "Any isotope of proj_Z \u2014 divide total MeV by A to get MeV/u"
      }
    }
  }
