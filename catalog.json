      "projectiles": ["n", "p", "d", "h", "a"],
      "data_type": "cross_sections",
      "version": "latest",
      "path": "iaea-medical/xs/"
    },
    "exfor": {
      "name": "EXFOR",
      "description": "Experimental nuclear reaction data (IAEA NDS)",
      "source_url": "https://www-nds.iaea.org/exfor/",
      "projectiles": ["n", "p", "d", "t", "h", "a"],
      "data_type": "experimental_cross_sections",
      "version": "latest",
      "path": "exfor/"
    }
  },
  "shared": {
    "meta": {
      "path": "meta/",
      "files": {
        "abundances": "abundances.parquet",
        "decay": "decay.parquet",
        "elements": "elements.parquet"
      }
    },
    "stopping": {
      "path": "stopping/",
      "files": {
        "stopping": "stopping.parquet"
      },
      "sources": ["PSTAR", "ASTAR", "ICRU73", "MSTAR"]
    }
  }
}
